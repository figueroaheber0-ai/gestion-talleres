generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  maxCapacity      Int      @default(10)
  subscriptionPlan String   @default("free")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users          User[]
  clients        Client[]
  vehicles       Vehicle[]
  appointments   Appointment[]
  workOrders     WorkOrder[]
  inventoryItems InventoryItem[]
}

model User {
  id                   String      @id @default(uuid())
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id])
  name                 String
  email                String
  role                 String      @default("mechanic")
  passwordHash         String
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  mechanicWorkOrders   WorkOrder[] @relation("MechanicWorkOrders")
  sessions             Session[]

  @@unique([tenantId, email])
}

model Client {
  id            String               @id @default(uuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  name          String
  phone         String?
  email         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  vehicles      Vehicle[]
  portalAccount ClientPortalAccount?
  sessions      Session[]

  @@unique([tenantId, email])
}

model ClientPortalAccount {
  id           String   @id @default(uuid())
  clientId     String   @unique
  client       Client   @relation(fields: [clientId], references: [id])
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vehicle {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  plate        String
  brand        String
  model        String
  year         Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  workOrders   WorkOrder[]

  @@unique([tenantId, plate])
}

model Appointment {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  vehicleId String
  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id])
  date      DateTime   @db.Date
  time      String
  reason    String
  status    String     @default("pending")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workOrder WorkOrder?
}

model WorkOrder {
  id                          String          @id @default(uuid())
  tenantId                    String
  tenant                      Tenant          @relation(fields: [tenantId], references: [id])
  vehicleId                   String
  vehicle                     Vehicle         @relation(fields: [vehicleId], references: [id])
  appointmentId               String?         @unique
  appointment                 Appointment?    @relation(fields: [appointmentId], references: [id])
  status                      String          @default("pending")
  diagnostic                  String?         @db.Text
  laborCost                   Float           @default(0)
  totalCost                   Float           @default(0)
  recommendedNextRevisionDate DateTime?
  recommendedNextRevisionNote String?         @db.Text
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  mechanicId                  String?
  mechanic                    User?           @relation("MechanicWorkOrders", fields: [mechanicId], references: [id])
  parts                       WorkOrderPart[]
  updates                     ClientUpdate[]
}

model ClientUpdate {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  title       String
  message     String    @db.Text
  visibility  String    @default("client")
  createdAt   DateTime  @default(now())
}

model InventoryItem {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  name           String
  sku            String?
  stockQuantity  Int             @default(0)
  minAlert       Int             @default(5)
  price          Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workOrderParts WorkOrderPart[]
}

model WorkOrderPart {
  workOrderId      String
  workOrder        WorkOrder     @relation(fields: [workOrderId], references: [id])
  itemId           String
  item             InventoryItem @relation(fields: [itemId], references: [id])
  quantity         Int
  unitPrice        Float
  internalCost     Float         @default(0)
  providedByClient Boolean       @default(false)

  @@id([workOrderId, itemId])
}

model Session {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  actorType  String
  role       String
  email      String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  active     Boolean  @default(true)
  userAgent  String?
  ipAddress  String?
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  maxCapacity      Int      @default(10)
  subscriptionPlan String   @default("free")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users          User[]
  clients        Client[]
  vehicles       Vehicle[]
  appointments   Appointment[]
  workOrders     WorkOrder[]
  inventoryItems InventoryItem[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  role         String   @default("mechanic") // admin, receptionist, mechanic
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mechanicWorkOrders WorkOrder[] @relation("MechanicWorkOrders")

  @@unique([tenantId, email])
}

model Client {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles Vehicle[]
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  plate     String
  brand     String
  model     String
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  workOrders   WorkOrder[]

  @@unique([tenantId, plate])
}

model Appointment {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  date      DateTime @db.Date // Just the date part
  time      String // e.g. "10:30"
  reason    String
  status    String   @default("pending") // pending, confirmed, cancelled, finished
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrder WorkOrder?
}

model WorkOrder {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  vehicleId     String
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        String       @default("pending") // pending, estimating, waiting_parts, repairing, finished, delivered
  diagnostic    String?      @db.Text
  laborCost     Float        @default(0)
  totalCost     Float        @default(0)

  // Próxima revisión sugerida para el cliente
  recommendedNextRevisionDate DateTime?
  recommendedNextRevisionNote String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Empleado asignado para reportes de ganancias
  mechanicId String?
  mechanic   User?   @relation("MechanicWorkOrders", fields: [mechanicId], references: [id])

  parts WorkOrderPart[]
}

model InventoryItem {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  sku           String?
  stockQuantity Int      @default(0)
  minAlert      Int      @default(5)
  price         Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workOrderParts WorkOrderPart[]
}

model WorkOrderPart {
  workOrderId      String
  workOrder        WorkOrder     @relation(fields: [workOrderId], references: [id])
  itemId           String
  item             InventoryItem @relation(fields: [itemId], references: [id])
  quantity         Int
  unitPrice        Float // Precio cobrado al cliente
  internalCost     Float         @default(0) // Precio que pagó el taller
  providedByClient Boolean       @default(false)

  @@id([workOrderId, itemId])
}
